---
interface Props {
  href: string;
  term: string;
  definition: string;
  category:
    | 'contratti-lavoro'
    | 'identita-digitale'
    | 'fisco-previdenza'
    | 'sanita'
    | 'generale';
}

const { href, term, definition, category } = Astro.props;

const categoryLabels = {
  'contratti-lavoro': 'Contratti e lavoro',
  'identita-digitale': 'Identità digitale',
  'fisco-previdenza': 'Fisco e previdenza',
  sanita: 'Sanità',
  generale: 'Generale',
} as const;
---

<article class="border-t border-divider py-5 first:border-t-0 first:pt-0">
  <a href={href} class="group flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
    <div class="space-y-2">
      <h2 class="font-serif text-3xl leading-none tracking-tight text-ink transition-colors duration-150 group-hover:text-accent md:text-[2.2rem]">
        {term}
      </h2>
      <p class="max-w-2xl text-base leading-8 text-ink/72">
        {definition}
      </p>
    </div>
    <span class="text-[0.68rem] uppercase tracking-[0.18em] text-ink/50">
      {categoryLabels[category]}
    </span>
  </a>
</article>
