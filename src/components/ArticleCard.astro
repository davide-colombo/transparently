---
interface Props {
  href: string;
  title: string;
  description: string;
  date: Date;
  category: 'contratti-lavoro' | 'identita-digitale' | 'fisco-previdenza' | 'sanita';
  difficulty: 'base' | 'intermedio' | 'avanzato';
}

const { href, title, description, date, category, difficulty } = Astro.props;

const categoryLabels = {
  'contratti-lavoro': 'Contratti e lavoro',
  'identita-digitale': 'Identità digitale',
  'fisco-previdenza': 'Fisco e previdenza',
  sanita: 'Sanità',
} as const;

const difficultyLabels = {
  base: 'Base',
  intermedio: 'Intermedio',
  avanzato: 'Avanzato',
} as const;

const formattedDate = new Intl.DateTimeFormat('it-IT', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(date);
---

<article class="border-t border-divider py-6 first:border-t-0 first:pt-0">
  <a href={href} class="group block space-y-3">
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-[0.7rem] uppercase tracking-[0.18em] text-ink/55">
      <span>{categoryLabels[category]}</span>
      <span>{difficultyLabels[difficulty]}</span>
      <time datetime={date.toISOString()}>{formattedDate}</time>
    </div>
    <h2 class="max-w-3xl font-serif text-3xl leading-[1.02] tracking-tight text-ink transition-colors duration-150 group-hover:text-accent md:text-4xl">
      {title}
    </h2>
    <p class="max-w-2xl text-base leading-8 text-ink/72">
      {description}
    </p>
  </a>
</article>
