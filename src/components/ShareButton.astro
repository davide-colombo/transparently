<style>
  /* ── Inline variant (near title) ── */
  .share-inline {
    position: relative;
    display: inline-flex;
    align-items: center;
    vertical-align: middle;
  }
  .share-inline-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: 1px solid var(--color-accent);
    border-radius: 999px;
    background: var(--color-accent);
    color: var(--color-paper);
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
  }
  .share-inline-btn:hover {
    background: var(--color-ink);
    border-color: var(--color-ink);
    color: var(--color-paper);
  }
  .share-panel {
    position: absolute;
    top: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 4px;
    padding: 6px 8px;
    background: var(--color-paper);
    border: 1px solid var(--color-divider);
    border-radius: 8px;
    box-shadow: 0 4px 12px color-mix(in srgb, var(--color-ink) 8%, transparent);
    z-index: 50;
  }
  .share-panel--hidden {
    display: none;
  }
  .share-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    color: var(--color-accent);
    text-decoration: none;
    border: none;
    background: transparent;
    cursor: pointer;
    transition: color 0.15s, background-color 0.15s;
  }
  .share-link:hover {
    color: var(--color-paper);
    background: var(--color-accent);
  }

  /* ── Block variant (bottom of article) ── */
  .share-block {
    margin: 2.5rem 0;
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-divider);
  }
  .share-block-text {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 0.95rem;
    color: color-mix(in srgb, var(--color-ink) 72%, var(--color-paper));
    margin: 0 0 1rem 0;
  }
  .share-block-buttons {
    position: relative;
  }
  .share-native-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 20px;
    border: 1px solid var(--color-accent);
    border-radius: 6px;
    background: var(--color-accent);
    color: var(--color-paper);
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
  }
  .share-native-btn:hover {
    background: var(--color-ink);
    border-color: var(--color-ink);
    color: var(--color-paper);
  }
  .share-fallback {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .share-fallback--hidden {
    display: none;
  }
  .share-fallback-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border: 1px solid var(--color-accent);
    border-radius: 6px;
    background: var(--color-accent);
    color: var(--color-paper);
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 450;
    text-decoration: none;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s, background-color 0.15s;
  }
  .share-fallback-btn:hover {
    color: var(--color-paper);
    border-color: var(--color-ink);
    background: var(--color-ink);
  }

  /* ── About variant ── */
  .share-about {
    margin: 3rem 0 0 0;
    padding: 2rem 0 0 0;
    border-top: 1px solid var(--color-divider);
  }
  .share-about-text {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 1rem;
    color: var(--color-ink);
    margin: 0 0 1.25rem 0;
  }

  /* ── Copy feedback ── */
  .share-copied-feedback {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 0.75rem;
    color: var(--color-accent);
    margin-left: 8px;
    animation: fadeIn 0.15s ease-out;
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>

<script>
  function initShareButtons() {
    function getShareData(el) {
      const container = el.closest('[data-share-title]');
      if (!container) return null;
      return {
        title: container.dataset.shareTitle || '',
        url: container.dataset.shareUrl || window.location.href,
        text: container.dataset.shareDescription || '',
      };
    }

    function buildHref(channel, data) {
      const fullText = data.title + (data.text ? ' — ' + data.text : '');
      switch (channel) {
        case 'whatsapp':
          return 'https://wa.me/?text=' + encodeURIComponent(fullText + ' ' + data.url);
        case 'telegram':
          return 'https://t.me/share/url?url=' + encodeURIComponent(data.url) + '&text=' + encodeURIComponent(fullText);
        case 'linkedin':
          return 'https://www.linkedin.com/sharing/share-offsite/?url=' + encodeURIComponent(data.url);
        case 'twitter':
          return 'https://twitter.com/intent/tweet?url=' + encodeURIComponent(data.url) + '&text=' + encodeURIComponent(fullText);
        case 'email':
          return 'mailto:?subject=' + encodeURIComponent(data.title) + '&body=' + encodeURIComponent((data.text ? data.text + '\n\n' : '') + data.url);
        default:
          return '#';
      }
    }

    // ── Inline variant: toggle panel ──
    document.querySelectorAll('.share-inline-btn').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var data = getShareData(btn);
        if (!data) return;

        if (navigator.share) {
          navigator.share({ title: data.title, text: data.text, url: data.url }).catch(function() {});
          return;
        }

        var panel = btn.parentElement.querySelector('.share-panel');
        var isHidden = panel.classList.contains('share-panel--hidden');

        // Close all other panels
        document.querySelectorAll('.share-panel').forEach(function(p) {
          p.classList.add('share-panel--hidden');
        });

        if (isHidden) {
          // Set hrefs
          panel.querySelectorAll('[data-channel]').forEach(function(link) {
            var ch = link.dataset.channel;
            if (ch !== 'copy') {
              link.href = buildHref(ch, data);
            }
          });
          panel.classList.remove('share-panel--hidden');
        }
      });
    });

    // ── Block / About variant: native share or show fallback ──
    document.querySelectorAll('.share-native-btn').forEach(function(btn) {
      var data = getShareData(btn);
      if (!data) return;

      if (navigator.share) {
        btn.addEventListener('click', function() {
          navigator.share({ title: data.title, text: data.text, url: data.url }).catch(function() {});
        });
      } else {
        // Hide native button, show fallback
        var fallback = btn.parentElement.querySelector('.share-fallback');
        btn.style.display = 'none';
        fallback.classList.remove('share-fallback--hidden');

        // Set hrefs
        fallback.querySelectorAll('[data-channel]').forEach(function(link) {
          var ch = link.dataset.channel;
          if (ch !== 'copy') {
            link.href = buildHref(ch, data);
          }
        });
      }
    });

    // ── Copy link handler ──
    document.querySelectorAll('[data-channel="copy"]').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        var data = getShareData(btn);
        if (!data) return;

        navigator.clipboard.writeText(data.url).then(function() {
          // Remove any existing feedback
          var existing = btn.parentElement.querySelector('.share-copied-feedback');
          if (existing) existing.remove();

          var feedback = document.createElement('span');
          feedback.className = 'share-copied-feedback';
          feedback.textContent = 'Copiato!';
          btn.after(feedback);
          setTimeout(function() { feedback.remove(); }, 2000);
        }).catch(function() {});
      });
    });

    // ── Close inline panels on outside click ──
    document.addEventListener('click', function() {
      document.querySelectorAll('.share-panel').forEach(function(p) {
        p.classList.add('share-panel--hidden');
      });
    });

    // Prevent panel clicks from closing
    document.querySelectorAll('.share-panel').forEach(function(p) {
      p.addEventListener('click', function(e) { e.stopPropagation(); });
    });
  }

  // Run on load and on Astro page transitions
  initShareButtons();
  document.addEventListener('astro:after-swap', initShareButtons);
</script>
