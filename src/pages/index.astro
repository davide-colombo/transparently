---
import { getCollection } from 'astro:content';
import ArticleCard from '../components/ArticleCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const articles = await getCollection('articoli', ({ data }) => !data.draft);
const glossaryEntries = await getCollection('glossario');

const articlesById = new Map(articles.map((article) => [article.id, article]));
const glossaryById = new Map(glossaryEntries.map((entry) => [entry.id, entry]));

const getArticle = (id: string) => {
  const article = articlesById.get(id);

  if (!article) {
    throw new Error(`Missing homepage article: ${id}`);
  }

  return article;
};

const getGlossaryEntry = (id: string) => {
  const entry = glossaryById.get(id);

  if (!entry) {
    throw new Error(`Missing homepage glossary entry: ${id}`);
  }

  return entry;
};

const latestArticles = [...articles]
  .sort((a, b) => {
    const byDate = b.data.date.getTime() - a.data.date.getTime();

    return byDate !== 0 ? byDate : a.data.title.localeCompare(b.data.title, 'it');
  })
  .slice(0, 3);

const thematicPaths = [
  {
    title: 'Università',
    description: 'Iscrizione, tasse, ISEE, borse di studio e vita da fuorisede.',
    guideCount: 3,
    articleIds: [
      'universita-iscrizione-guida',
      'studente-fuorisede-residenza-medico',
      'borse-studio-dsu-domanda',
    ],
  },
  {
    title: 'Stage e tirocinio',
    description:
      'Guida completa, differenze, indennità per regione, irregolarità e apprendistato.',
    guideCount: 5,
    articleIds: [
      'stage-tirocinio-guida-completa',
      'stage-curriculare-vs-extracurriculare',
      'stage-irregolare-come-riconoscerlo',
    ],
  },
  {
    title: 'Contratti di lavoro',
    description:
      'Determinato, indeterminato, busta paga, periodo di prova, dimissioni e TFR.',
    guideCount: 6,
    articleIds: [
      'contratto-tempo-determinato',
      'come-leggere-busta-paga',
      'dimissioni-telematiche',
    ],
  },
  {
    title: 'Identità digitale',
    description:
      'SPID, CIE, PEC, App IO, firma digitale, domicilio digitale e pagoPA.',
    guideCount: 7,
    articleIds: ['spid-guida-completa', 'app-io-guida-completa', 'cie-guida-completa'],
  },
].map((path) => ({
  ...path,
  articles: path.articleIds.map(getArticle),
}));

const glossaryTeaserEntries = [
  { entry: getGlossaryEntry('spid'), label: 'SPID' },
  { entry: getGlossaryEntry('tfr'), label: 'TFR' },
  { entry: getGlossaryEntry('isee'), label: 'ISEE' },
  { entry: getGlossaryEntry('pec'), label: 'PEC' },
  { entry: getGlossaryEntry('ccnl'), label: 'CCNL' },
];
const glossaryCountLabel =
  glossaryEntries.length === 1
    ? '1 termine della burocrazia italiana, spiegato in parole semplici.'
    : `${glossaryEntries.length} termini della burocrazia italiana, spiegati in parole semplici.`;
const methodCopy =
  'Qui trovi spiegazioni costruite per chi sta affrontando il primo contratto di lavoro o il primo accesso a SPID o alla CIE: un punto di orientamento con fonti istituzionali, scritto in modo chiaro e senza paternalismi.';
---

<BaseLayout
  title="Transparently"
  description="Guida civica in italiano per orientarsi tra contratti, identità digitale, fisco e servizi pubblici."
>
  <section class="mx-auto max-w-6xl">
    <div class="max-w-4xl">
      <p class="text-[0.74rem] uppercase tracking-[0.24em] text-ink/55">Guida civica</p>
      <h1 class="mt-4 max-w-3xl font-serif text-6xl leading-[0.92] tracking-tight text-ink md:text-[5.5rem]">
        La burocrazia italiana, spiegata.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-ink/72 md:text-xl">
        Transparently traduce linguaggio amministrativo, contratti, identità digitale e procedure
        pubbliche in italiano leggibile. Ogni guida parte da una domanda concreta e rimanda sempre
        a fonti istituzionali verificabili.
      </p>
    </div>
  </section>

  <section class="mx-auto mt-16 max-w-6xl border-t border-divider pt-8">
    <div class="max-w-3xl">
      <p class="text-[0.74rem] uppercase tracking-[0.24em] text-ink/55">Metodo</p>
      <p class="mt-4 text-base leading-8 text-ink/72 md:text-lg">
        {methodCopy}
      </p>
    </div>
  </section>

  <section class="mx-auto mt-16 max-w-6xl border-t border-divider pt-10">
    <div class="max-w-3xl">
      <p class="text-[0.74rem] uppercase tracking-[0.24em] text-ink/55">Percorsi tematici</p>
      <h2 class="mt-3 font-serif text-4xl tracking-tight text-ink md:text-5xl">
        Un punto di ingresso per ogni momento.
      </h2>
    </div>

    <div class="mt-10">
      {thematicPaths.map((path) => (
        <article class="grid gap-8 border-t border-divider py-8 md:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] md:gap-12">
          <div class="space-y-4">
            <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
              <h3 class="font-serif text-4xl leading-none tracking-tight text-ink md:text-[2.7rem]">
                {path.title}
              </h3>
              <p class="text-[0.72rem] uppercase tracking-[0.2em] text-ink/55">
                {path.guideCount} {path.guideCount === 1 ? 'guida' : 'guide'}
              </p>
            </div>
            <p class="max-w-md text-base leading-8 text-ink/72">
              {path.description}
            </p>
          </div>

          <div class="flex flex-col gap-6">
            <ul class="space-y-4">
              {path.articles.map((article) => (
                <li>
                  <a
                    href={`/articoli/${article.id}`}
                    class="font-serif text-[1.75rem] leading-[1.05] tracking-tight text-ink transition-colors duration-150 hover:text-accent md:text-[2.1rem]"
                  >
                    {article.data.title}
                  </a>
                </li>
              ))}
            </ul>

            <div>
              <a
                href="/articoli"
                class="text-sm font-medium text-accent transition-opacity duration-150 hover:opacity-80"
              >
                Tutte le guide &rarr;
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto mt-16 max-w-6xl border-t border-divider pt-10">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-[0.74rem] uppercase tracking-[0.24em] text-ink/55">Articoli</p>
        <h2 class="mt-3 font-serif text-4xl tracking-tight text-ink">Ultime guide</h2>
      </div>
      <a
        href="/articoli"
        class="text-sm font-medium text-accent transition-opacity duration-150 hover:opacity-80"
      >
        Tutti gli articoli &rarr;
      </a>
    </div>

    <div class="mt-8">
      {latestArticles.map((article) => (
        <ArticleCard
          href={`/articoli/${article.id}`}
          title={article.data.title}
          description={article.data.description}
          date={article.data.date}
          category={article.data.category}
          difficulty={article.data.difficulty}
        />
      ))}
    </div>
  </section>

  <section class="mx-auto mt-16 max-w-6xl border-t border-divider pt-10">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-3xl">
        <p class="text-[0.74rem] uppercase tracking-[0.24em] text-ink/55">Glossario</p>
        <h2 class="mt-3 font-serif text-4xl tracking-tight text-ink">Termini da aprire al bisogno</h2>
        <p class="mt-4 text-base leading-8 text-ink/72 md:text-lg">
          {glossaryCountLabel}
        </p>
      </div>
      <a
        href="/glossario"
        class="text-sm font-medium text-accent transition-opacity duration-150 hover:opacity-80"
      >
        Apri il glossario &rarr;
      </a>
    </div>

    <div class="mt-8 flex flex-wrap gap-x-6 gap-y-4 md:gap-x-8">
      {glossaryTeaserEntries.map(({ entry, label }) => (
        <a
          href={`/glossario/${entry.id}`}
          class="font-serif text-[1.95rem] leading-none tracking-tight text-ink transition-colors duration-150 hover:text-accent md:text-[2.4rem]"
        >
          {label}
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
