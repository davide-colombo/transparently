---
import { getCollection } from 'astro:content';
import GlossaryEntry from '../../components/GlossaryEntry.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const categoryOrder = [
  'contratti-lavoro',
  'identita-digitale',
  'fisco-previdenza',
  'sanita',
  'generale',
] as const;

const categoryLabels = {
  'contratti-lavoro': 'Contratti di lavoro',
  'identita-digitale': 'Identità digitale',
  'fisco-previdenza': 'Fisco e previdenza',
  sanita: 'Sanità',
  generale: 'Generale',
} as const;

const entries = await getCollection('glossario');

const groupedEntries = categoryOrder
  .map((category) => ({
    category,
    label: categoryLabels[category],
    entries: entries
      .filter((entry) => entry.data.category === category)
      .sort((a, b) => a.data.term.localeCompare(b.data.term, 'it')),
  }))
  .filter((group) => group.entries.length > 0);
---

<BaseLayout
  title="Glossario"
  description="Definizioni rapide dei termini più comuni della burocrazia italiana."
>
  <section class="mx-auto max-w-6xl">
    <div class="max-w-3xl">
      <p class="text-[0.74rem] uppercase tracking-[0.24em] text-ink/55">Lessico</p>
      <h1 class="mt-4 font-serif text-5xl leading-none tracking-tight text-ink md:text-6xl">
        Glossario
      </h1>
      <p class="mt-5 text-lg leading-8 text-ink/72">
        Sigle, formule e parole che ricorrono nei documenti pubblici e nei contratti. Ogni voce
        prova a togliere ambiguità, non ad aggiungerne.
      </p>
    </div>

    <nav class="mt-10 border-t border-divider pt-6" aria-label="Indice rapido glossario">
      <p class="text-[0.72rem] uppercase tracking-[0.2em] text-ink/55">Indice rapido</p>
      <div class="mt-4 flex flex-wrap gap-x-6 gap-y-3 text-sm leading-6">
        {groupedEntries.map((group) => (
          <a href={`#${group.category}`} class="font-medium text-accent">
            {group.label}
          </a>
        ))}
      </div>
    </nav>

    <div class="mt-12 space-y-16">
      {groupedEntries.map((group) => (
        <section id={group.category} class="scroll-mt-28">
          <div class="mb-6 border-t border-divider pt-6">
            <h2 class="border-l-4 border-accent pl-4 font-serif text-4xl tracking-tight text-ink">
              {group.label}
            </h2>
          </div>
          <div>
            {group.entries.map((entry) => (
              <GlossaryEntry
                href={`/glossario/${entry.id}`}
                term={entry.data.term}
                definition={entry.data.definition}
                category={entry.data.category}
              />
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
